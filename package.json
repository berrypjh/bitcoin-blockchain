{
  "name": "bitcoin-blockchain",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many -t start",
    "dev:peer1": "nx run-many -t peer1",
    "dev:peer2": "nx run-many -t peer2",
    "server": "nx run @bitcoin-blockchain/server:start",
    "server:dev": "nx run @bitcoin-blockchain/server:dev",
    "client": "nx run @bitcoin-blockchain/client:start",
    "build": "nx run @bitcoin-blockchain/client:build",
    "format": "prettier --write \"apps/**/*.{js,jsx,json}\" \"*.json\" \"*.yaml\""
  },
  "devDependencies": {
    "nx": "^22.7.0",
    "prettier": "^3.8.3"
  }
}
