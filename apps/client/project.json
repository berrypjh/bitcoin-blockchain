{
  "name": "@bitcoin-blockchain/client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vite build",
        "cwd": "{projectRoot}"
      }
    },
    "peer1": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --port 3001",
        "cwd": "{projectRoot}",
        "env": {
          "HTTP_PORT": "4001"
        }
      }
    },
    "peer2": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --port 3002",
        "cwd": "{projectRoot}",
        "env": {
          "HTTP_PORT": "4002"
        }
      }
    }
  }
}
