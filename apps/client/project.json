{
  "name": "@bitcoin-blockchain/client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-scripts start",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "react-scripts build",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-scripts test",
        "cwd": "{projectRoot}"
      }
    },
    "peer1": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-scripts start",
        "cwd": "{projectRoot}",
        "env": {
          "PORT": "3001",
          "HTTP_PORT": "4001"
        }
      }
    },
    "peer2": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-scripts start",
        "cwd": "{projectRoot}",
        "env": {
          "PORT": "3002",
          "HTTP_PORT": "4002"
        }
      }
    }
  }
}
